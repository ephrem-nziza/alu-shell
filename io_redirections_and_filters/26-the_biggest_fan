#!/bin/bash

# Script to parse web server logs in TSV format and display top 11 hosts by request count
# Format: host logname time method url response bytes

if [ $# -eq 0 ]; then
    echo "Usage: $0 <logfile>" >&2
    exit 1
fi

logfile="$1"

if [ ! -f "$logfile" ]; then
    echo "Error: File '$logfile' not found" >&2
    exit 1
fi

# Read the file, extract the first column (host), count occurrences, sort by count descending,
# and display the top 11 hosts
awk '
    NR > 1 {  # Skip header row if present
        host = $1
        if (host != "") {
            hosts[host]++
        }
    }
    END {
        # Sort by count descending
        n = 0
        for (h in hosts) {
            sorted[++n] = h " " hosts[h]
        }
        
        # Bubble sort to order by request count (second field) descending
        for (i = 1; i <= n; i++) {
            for (j = i + 1; j <= n; j++) {
                split(sorted[i], a, " ")
                split(sorted[j], b, " ")
                # Compare counts in descending order
                if (a[2] < b[2]) {
                    temp = sorted[i]
                    sorted[i] = sorted[j]
                    sorted[j] = temp
                }
            }
        }
        
        # Print header
        printf "%-40s %s\n", "Host/IP Address", "Request Count"
        printf "%-40s %s\n", "-------------------------------------", "-------------"
        
        # Print top 11
        limit = (n < 11) ? n : 11
        for (i = 1; i <= limit; i++) {
            split(sorted[i], parts, " ")
            printf "%-40s %d\n", parts[1], parts[2]
        }
    }
' "$logfile"
